# Web3Auth — criar projeto em https://dashboard.web3auth.io
# Usar "Sapphire Devnet" para desenvolvimento e "Sapphire Mainnet" para produção
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=

# PostgreSQL — injetado automaticamente pelo docker-compose no devcontainer
# Para outros ambientes, ajustar conforme necessário
DATABASE_URL=postgresql://cozap:cozap@db:5432/cozap
