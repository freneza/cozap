{
  "name": "coZap Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "options": ["--network=host"]
  },

  // Monta o diretório .claude do host para preservar memória, histórico e
  // configurações do Claude Code entre sessões e rebuilds do container.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],

  // Variáveis de ambiente disponíveis no container.
  // ANTHROPIC_API_KEY é lida do ambiente do host — nunca commitada no repo.
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  // Porta do Next.js dev server
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "notify"
    }
  },

  // Instala dependências do monorepo após o container ser criado
  "postCreateCommand": "pnpm install",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "NomicFoundation.hardhat-solidity",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian",
        "bierner.markdown-mermaid"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "typescript.preferences.importModuleSpecifier": "non-relative",
        "[solidity]": {
          "editor.defaultFormatter": "NomicFoundation.hardhat-solidity"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "node"
}
