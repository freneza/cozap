{
  "name": "coZap Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/coZap",

  // Monta o diretório .claude do host para preservar memória, histórico e
  // configurações do Claude Code entre sessões e rebuilds do container.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],

  // Variáveis de ambiente disponíveis no container.
  // ANTHROPIC_API_KEY é lida do ambiente do host — nunca commitada no repo.
  // DATABASE_URL é injetada pelo docker-compose.yml.
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },

  // Porta do Next.js dev server e do PostgreSQL
  "forwardPorts": [3000, 5432],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },

  // Instala dependências e sincroniza schema com o banco após o container ser criado
  "postCreateCommand": "pnpm install && pnpm --filter @cozap/web exec prisma db push",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "NomicFoundation.hardhat-solidity",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian",
        "bierner.markdown-mermaid",
        "cweijan.vscode-postgresql-client2",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "typescript.preferences.importModuleSpecifier": "non-relative",
        "[solidity]": {
          "editor.defaultFormatter": "NomicFoundation.hardhat-solidity"
        },
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  "remoteUser": "node"
}
